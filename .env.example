# =====================================================================
# NexusLeague — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# ---------- Database (REQUIRED) --------------------------------------
# Postgres connection string used by both the web app and the Discord
# bot. For local dev with docker-compose this matches the service in
# docker-compose.yml. For Railway / production paste the URL given by
# your DB provider here.
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# ---------- Web app session secret (REQUIRED) ------------------------
# Used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be >= 32 chars and DIFFERENT in every environment.
SECRET_KEY=replace-me-with-long-random-string

# ---------- Discord OAuth (REQUIRED) ---------------------------------
# Create an application at https://discord.com/developers/applications
# Add a redirect URI matching DISCORD_REDIRECT_URI exactly.
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret
DISCORD_REDIRECT_URI=http://localhost:8000/oauth-callback

# ---------- Discord bot (only for nexus-league-bot repo) -------------
# DISCORD_BOT_TOKEN=your-bot-token

# ---------- OpenAI (optional, only if /headline command used) --------
# OPENAI_API_KEY=sk-...

# ---------- Debug toggles --------------------------------------------
# Set to 1 to log inbound companion-app payloads (verbose, dev-only).
COMPANION_DEBUG_LOG=0
